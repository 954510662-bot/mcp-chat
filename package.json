{
  "name": "mcp-chat-server",
  "version": "1.0.0",
  "description": "Multi-AI group chat MCP server",
  "license": "MIT",
  "author": "mcp-chat contributors",
  "homepage": "https://github.com/954510662-bot/mcp-chat",
  "repository": {
    "type": "git",
    "url": "https://github.com/954510662-bot/mcp-chat.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "multi-agent",
    "chat"
  ],
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "mcp-chat": "platform.js",
    "mcp-chat-server": "src/server.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./agents": "./src/agents/index.js",
    "./tools": "./src/tools/toolManager.js",
    "./platform": "./src/platform/multiAgentPlatform.js"
  },
  "scripts": {
    "start": "node platform.js",
    "start:http": "node http-server.js",
    "start:mcp": "node src/server.js",
    "dev": "node --watch platform.js",
    "example": "node example-usage.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src",
    "README.md",
    "compatibility.md",
    ".env.example",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "zod": "^4.1.12"
  }
}
