# ============== Provider 配置 ==============
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
DEFAULT_MODEL=gpt-4o-mini
PROVIDER_TIMEOUT_MS=25000
PROVIDER_RETRIES=2

# ============== MCP Server 传输模式 ==============
MCP_TRANSPORT=stdio
MCP_PORT=3000
MCP_AUTH_TOKEN=
MCP_PERSISTENCE=file
MCP_STORE_FILE=./data/store.json
MCP_RETENTION_DAYS=0

# ============== Agent Connectors ==============
# Claude Code (本地 CLI)
CLAUDE_CODE_CWD=D:\\ClaudeCode\\mcp-chat

# OpenClaw (远程)
OPENCLAW_ENDPOINT=http://你的服务器IP:端口/execute

# Hermes (云服务器)
HERMES_ENDPOINT=http://你的云服务器IP:端口/execute
